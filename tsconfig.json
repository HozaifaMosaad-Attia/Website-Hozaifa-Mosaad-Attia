{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "ESNext",
    "target": "ES6",
    
    "lib": ["ESNext", "DOM"],

    "sourceMap": true,
    "declaration": true,
    
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "noUnusedLocals": false, 
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,

    "removeComments": true,
    "moduleDetection": "force"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}